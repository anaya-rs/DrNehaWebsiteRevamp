DATABASE_URL=postgresql://user:password@localhost:5432/drnehasood
JWT_SECRET=change_this_to_a_long_random_string_at_least_32_chars
UPLOAD_DIR=./server/uploads
MAX_FILE_SIZE_MB=20
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
SMTP_FROM_NAME=Dr. Neha Sood Clinic
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
PUBLIC_SITE_URL=http://localhost:5173
PORT=4000

# ─── AWS S3 (media storage) ──────────────────────────────────────────
# Leave MEDIA_STORAGE=local to keep using the ./server/uploads folder.
# Set MEDIA_STORAGE=s3 and fill in the rest to store all uploads on S3.
MEDIA_STORAGE=local
AWS_REGION=ap-south-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional. Prefix inside the bucket for this site's media, e.g. "drneha/".
AWS_S3_PREFIX=
# How long (seconds) signed media URLs stay valid. 3600 = 1 hour.
AWS_SIGNED_URL_TTL=3600
